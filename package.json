{
  "name": "@bunit/monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "A collection of high-performance tools and utilities exclusively built for the Bun ecosystem",
  "keywords": [
    "build",
    "bun",
    "developer-tools",
    "monorepo",
    "performance",
    "toolkit",
    "typescript",
    "utilities"
  ],
  "homepage": "https://github.com/DemoMacro/BunIt#readme",
  "bugs": {
    "url": "https://github.com/DemoMacro/BunIt/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/BunIt.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@bunit/build' dev && bun run --workspaces dev",
    "build": "bun run --workspaces build",
    "lint": "basis lint",
    "fmt": "basis fmt",
    "postinstall": "bun run dev && basis git setup"
  },
  "devDependencies": {
    "@bunit/build": "workspace:*",
    "@funish/basis": "0.2.16",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0"
  }
}
